# --- HTTP ---
HTTP_ADDR=:8080

# --- Database ---
POSTGRES_USER=sdano
POSTGRES_PASSWORD=sdano-dev-password
POSTGRES_DB=sdano
DATABASE_URL=postgres://sdano:sdano-dev-password@localhost:5432/sdano?sslmode=disable

# --- Object storage (MinIO in dev; managed S3-compatible in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sdano-evidence
S3_ACCESS_KEY=sdano-dev
S3_SECRET_KEY=sdano-dev-secret
S3_USE_PATH_STYLE=true

# --- Admin panel origin (CORS) ---
ADMIN_ORIGIN=http://localhost:3000

# --- Auth ---
# HS256 signing secret for staff access tokens. Generate a long random value
# in production (e.g. `openssl rand -base64 48`). Required.
JWT_SECRET=dev-insecure-change-me-min-32-bytes!!

# --- Reverse proxy ---
# Number of trusted reverse-proxy hops in front of the API. Used to resolve the
# real client IP from X-Forwarded-For for rate limiting. 0 (default) = the API is
# directly exposed (key on the TCP peer). The prod compose profile puts Caddy in
# front, so production sets this to 1.
TRUSTED_PROXY_COUNT=0

# --- Reports ---
# Headless-Chrome DevTools Protocol endpoint the report worker renders PDFs
# against (deploy/docker-compose.yml's headless-shell service). Not required;
# defaults to a local dev instance.
CHROME_CDP_URL=http://localhost:9222
